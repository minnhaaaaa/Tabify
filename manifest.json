{
  "manifest_version": 3,
  "name": "Tabify",
  "version": "1.0.0",
  "description": "AI-powered tab organiser",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["model/model.json"],
      "matches": ["<all_urls>"]
    }
  ]
}