{
  "manifest_version": 3,
  "name": "Tabify",
  "version": "1.0.0",
  "description": "AI-powered tab organiser",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["model/model.json"],
      "matches": ["<all_urls>"]
    }
  ]
}